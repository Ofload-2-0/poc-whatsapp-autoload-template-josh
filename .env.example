# ── Safety ────────────────────────────────────────────────────
# TRUE (default) = logs what it would do, sends/writes NOTHING.
WA_DRY_RUN=true

# ── Timing ────────────────────────────────────────────────────
# 0 = fire immediately (testing) | 7200000 = 2 hours (production)
TRIGGER_AFTER_MS=0

# ── Rollout gating (fail-closed) ──────────────────────────────
WA_PHASE=carrier                       # load | team | carrier | all  (pick your test granularity)
WA_ENABLED_CARRIERS=                   # comma-separated carrier IDs      (phase=carrier)
WA_ENABLED_TEAM=                       # comma-separated team-member IDs  (phase=team — individual people)
WA_ENABLED_LOADS=                      # comma-separated load refs        (phase=load — single loads)
# WA_ALLOW_ALL=yes                     # required to enable phase=all (double gate)
WA_MAX_SENDS=1                         # hard cap on sends per run (blast-radius guard)

# ── EOS API (write-backs) — P5: obtain from backend/ops ───────
EOS_BASE_URL=https://dev.app.ofload.com
EOS_CLIENT_ID=
EOS_CLIENT_SECRET=

# ── HubSpot (send + reply) — P3: rotate the old leaked token ──
HUBSPOT_TOKEN=pat-ap1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HUBSPOT_WEBHOOK_CONFIRM=https://api-ap1.hubapi.com/automation/v4/webhook-triggers/23384711/CONFIRM_TRIGGER_ID
HUBSPOT_WEBHOOK_ETA=https://api-ap1.hubapi.com/automation/v4/webhook-triggers/23384711/ETA_TRIGGER_ID

# ── Note mapping (R2 — confirm category) ──────────────────────
WA_NOTE_CATEGORY=ETA
WA_NOTE_VISIBLE_TO_SHIPPER=false

# ── Reply handling ────────────────────────────────────────────
WA_UNRECOGNISED=ignore                 # ignore | yes

# ── Read-only DB (eligibility + contacts) ─────────────────────
# NOTE: the live dev app uses the "eos" database (NOT Ofload_site). cid in the
# carrier URL = carrier.id. Validated 2026-07-06 against THE FREIGHT COMP PTY LTD.
DATABASE_URL=postgres://postgres:password@host:5432/eos

# ── Tracking store (isolated; touches no shipment data) ───────
WA_TRACKING_BACKEND=local              # local (dev) | dynamo (prod)
# WA_TRACKING_TABLE=wa-pickup-tracking
